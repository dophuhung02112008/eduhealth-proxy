# Backend Proxy - EduHealth AI
# Copy file này thành .env và điền thông tin

# ── Groq API Key (CHAT - miễn phí vĩnh viễn) ─────────────
# Lấy key tại: https://console.groq.com/keys
# Free tier: 30 req/phút, model Llama 3.3 70B - cực xịn!
GROQ_API_KEY=gsk_xxxxx-your-groq-key-here

# ── Gemini API Key (SCAN ẢNH - miễn phí) ──────────────────
# Lấy key tại: https://aistudio.google.com/app/apikey
# Hoặc dùng lại key cũ: AIzaSyDrRi2ySyzKh98i4xike1gMtsXpch5tI5M
GEMINI_API_KEY=your-gemini-api-key-here

# ── Server config ──────────────────────────────────────────────
PORT=3001

# ── CORS - Cho phép origin Vercel ─────────────────────────────
ALLOWED_ORIGIN=https://eduhealth-ai.vercel.app
