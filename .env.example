# Backend Proxy - EduHealth AI
# Copy file này thành .env và điền thông tin thực tế

# ── Anthropic API Key (bắt buộc) ──────────────────────────────
# Lấy key tại: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx-your-actual-key-here

# ── Server config ──────────────────────────────────────────────
PORT=3001

# ── CORS - Chỉ cho phép origin này ─────────────────────────────
# Thay bằng URL Vercel của bạn (hoặc "*" để cho phép tất cả)
ALLOWED_ORIGIN=https://eduhealth-ai.vercel.app
